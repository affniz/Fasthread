# Backend environment variables. Copy to `.env` for local development:
#   cp .env.example .env
# On Render these are supplied by the Blueprint (render.yaml) / dashboard.

# --- Database (local Postgres) ---
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=your_username
DATABASE_PASSWORD=your_password
DATABASE_NAME=your_db_name

# --- Auth / JWT ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS origins ---
# The origins allowed to connect to the backend (comma-separated or JSON list).
# In production, set this to your frontend URL.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
