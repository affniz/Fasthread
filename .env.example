# Backend environment variables. Copy to `.env` for local development:
#   cp .env.example .env
# On Render these are supplied by the Blueprint (render.yaml) / dashboard.

# --- Database (local Postgres) ---
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fasthread

# --- Auth / JWT ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Frontend API base URL ---
# The URL the frontend uses to reach this API.
VITE_API_URL=http://localhost:8000
